# =========================================================================
# CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE - CONDOACCESS
# =========================================================================
#
# Para garantir que as variáveis permaneçam persistidas mesmo após reiniciar
# os containers efêmeros do Google AI Studio, por favor cadastre-as em:
# 
# ⚙️ Settings (Ícone de engrenagem à esquerda) -> Environment Variables / Secrets
#
# =========================================================================

# 1. INTEGRAÇÃO SUPABASE (OBRIGATÓRIO)
# URL de API principal do seu projeto do Supabase (ex: https://xxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chave pública "anon" para chamadas client-side pelo navegador
VITE_SUPABASE_ANON_KEY=

# Chave secreta de administrador "service_role" com bypass de RLS (usada apenas no servidor)
SUPABASE_SERVICE_ROLE_KEY=


# 2. INTELIGÊNCIA ARTIFICIAL (OBRIGATÓRIO PARA FUNÇÕES AI)
# Chave de API da Google GenAI para geração de murais, atas de assembleias e resumos
GEMINI_API_KEY=
